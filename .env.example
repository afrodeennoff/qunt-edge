# =========================================== 
 # QuntEdge Environment Configuration Template 
 # =========================================== 
 
# Database Configuration
# DATABASE_URL: use Supabase pooled TRANSACTION URL in production runtime (port 6543)
# DIRECT_URL: use direct DB URL for migrations only
DATABASE_URL="your_database_url_here"
DIRECT_URL="your_direct_url_here"

# Prisma Connection Pool Configuration
# Production-grade settings for handling concurrent queries
PG_POOL_MAX="20"                 # Max connections (20 for production, 5 for development)
PG_POOL_MIN="5"                  # Min connections (5 for production, 2 for development)
PG_POOL_IDLE_TIMEOUT_MS="30000"  # Close idle connections after 30s (production)
PG_POOL_CONNECT_TIMEOUT_MS="10000" # Fail fast if DB doesn't respond in 10s (production)
 
 # Supabase Configuration 
 NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here 
 NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here 
 NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here 
 
 # Service Role Key 
 SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here 
 
 # OpenAI Configuration 
 OPENAI_API_KEY=your_openai_api_key_here 
 # OpenAI-compatible AI provider (GLM)
 AI_BASE_URL=https://your-glm-openai-compatible-endpoint
 # Global default model (preferred)
 AI_MODEL_DEFAULT=zai/glm-4.7-flash
 # Legacy alias (still supported)
 AI_MODEL=glm-4.7-flash
 # Optional per-feature model overrides
 AI_MODEL_CHAT=openai/gpt-4o-mini
 AI_MODEL_SUPPORT=openai/gpt-4o-mini
 AI_MODEL_EDITOR=zai/glm-4.7-flash
 AI_MODEL_MAPPINGS=zai/glm-4.7-flash
 AI_MODEL_FORMAT_TRADES=zai/glm-4.7-flash
 AI_MODEL_ANALYSIS=zai/glm-4.7-flash
 AI_MODEL_SEARCH=zai/glm-4.7-flash
 AI_TIMEOUT_MS=60000
 AI_MAX_STEPS=10
 AI_LOG_SAMPLE_RATE=0.25
 
 # Discord OAuth 
 NEXT_PUBLIC_DISCORD_CONFIGURED=true 
 DISCORD_SECRET=your_discord_secret_here 
 DISCORD_ID=your_discord_id_here 
 REDIRECT_URL=http://localhost:3000/api/auth/callback 
 
 # Google OAuth 
 NEXT_PUBLIC_GOOGLE_CONFIGURED=true 
 
 # Security 
 ENCRYPTION_KEY=your_encryption_key_here 
 
 # Email Service 
 RESEND_API_KEY=your_resend_api_key_here 
 
 # GitHub Configuration 
 GITHUB_TOKEN=your_github_token_here 
 
 # Public URLs 
 NEXT_PUBLIC_SITE_URL=https://qunt-edge.vercel.app
 NEXT_PUBLIC_DISCORD_INVITATION=your_discord_invitation_url_here 
 NEXT_PUBLIC_REPO_OWNER=your_repo_owner_here 
 NEXT_PUBLIC_REPO_NAME=your_repo_name_here 
 # Optional CDN origin for Next.js static assets (example: https://cdn.example.com)
 NEXT_PUBLIC_CDN_URL=
 
 # Support Emails 
 SUPPORT_TEAM_EMAIL=support@qunt-edge.vercel.app 
 SUPPORT_EMAIL=support@qunt-edge.vercel.app 
 
 # Tutorial Videos 
 NEXT_PUBLIC_RITHMIC_PERFORMANCE_TUTORIAL_VIDEO=your_video_url_here 
 NEXT_PUBLIC_RITHMIC_ORDER_TUTORIAL_VIDEO=your_video_url_here 
 NEXT_PUBLIC_NINJATRADER_PERFORMANCE_TUTORIAL_VIDEO=your_video_url_here 
 
 # Whop Configuration 
WHOP_API_KEY=your_whop_api_key_here 
NEXT_PUBLIC_WHOP_APP_ID=your_whop_app_id_here 
NEXT_PUBLIC_WHOP_PRODUCT_URL=https://whop.com/dashboard/biz_jh37YZGpH5dWIY/ 
WHOP_COMPANY_ID=biz_jh37YZGpH5dWIY 
WHOP_CLIENT_SECRET=your_whop_client_secret_here 
WHOP_WEBHOOK_SECRET=your_whop_webhook_secret_here 

# Whop Plan IDs 
NEXT_PUBLIC_WHOP_MONTHLY_PLAN_ID=plan_55MGVOxft6Ipz 
NEXT_PUBLIC_WHOP_6MONTH_PLAN_ID=plan_LqkGRNIhM2A2z 
NEXT_PUBLIC_WHOP_YEARLY_PLAN_ID=plan_JWhvqxtgDDqFf 
NEXT_PUBLIC_WHOP_LIFETIME_PLAN_ID=your_plan_id_here 
NEXT_PUBLIC_WHOP_FREE_PLAN_ID=your_plan_id_here 
NEXT_PUBLIC_WHOP_TEAM_PLAN_ID=your_plan_id_here
 
 # Admin Configuration 
 ADMIN_USER_ID=your_admin_user_id_here 
 ADMIN_EMAIL_DOMAINS=your_admin_email_domains_here 
 
 # Cron Job Security 
 CRON_SECRET=your_cron_secret_here 
 UNSUBSCRIBE_TOKEN_SECRET=your_unsubscribe_token_secret_here_must_be_at_least_32_chars

# Local Redis cache (optional)
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Upstash Redis cache (optional, recommended for production)
# Enables distributed query cache across instances when REDIS_URL is not set
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
 
 # Logging 
 LOG_LEVEL=info

# Performance Optimization Rollout
# Feature flags for gradual rollout of performance improvements
NEXT_PUBLIC_ENABLE_SKELETON_LOADING=false
NEXT_PUBLIC_ENABLE_DEFERRED_COMPUTATIONS=false
NEXT_PUBLIC_ENABLE_LAZY_LOADING=false
NEXT_PUBLIC_ENABLE_QUERY_CACHING=false
# Percentage of users to show optimizations (0-100)
NEXT_PUBLIC_PERF_ROLLOUT_PCT=0
# Emergency rollback - set to 'true' to disable all optimizations immediately
NEXT_PUBLIC_EMERGENCY_ROLLBACK=false

# AI Provider Routing
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_ROUTER_ENABLED=true
AI_ROUTER_MODEL_FREE=openrouter/free
AI_ROUTER_MODEL_AUTO=openrouter/auto
AI_ROUTER_MODEL_LIQUID=liquid/lfm2-8b-a1b
# Legacy alias (still supported)
AI_ROUTER_LIQUID_MODEL=liquid/lfm2-8b-a1b
AI_ROUTER_PROVIDER_ORDER=openrouter
AI_ROUTER_MAX_PRICE_INPUT=0.05
AI_ROUTER_MAX_PRICE_OUTPUT=0.05
