[
  {
    "id": "TC001",
    "title": "Dashboard loads with core analytics widgets and charts visible (authenticated)",
    "description": "Verifies an authenticated user can open the dashboard and see key widgets/charts rendered.",
    "category": "Dashboard analytics and widgets",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /en/authentication"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Charts\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Trades\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
    "title": "Navigate from Dashboard to Strategies page using in-app navigation",
    "description": "Verifies user reaches Trade Desk (/dashboard/strategies) from authenticated dashboard navigation.",
    "category": "Dashboard analytics and widgets",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"/en/authentication\""
      },
      {
        "type": "action",
        "description": "Click on the password auth tab (data-testid=\"auth-password-tab\")"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into email input (data-testid=\"auth-email-input\")"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into password input (data-testid=\"auth-password-input\")"
      },
      {
        "type": "action",
        "description": "Click submit (data-testid=\"auth-password-submit\")"
      },
      {
        "type": "action",
        "description": "Click dashboard nav item data-testid=\"nav-trade-desk\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard/strategies\""
      }
    ]
  },
