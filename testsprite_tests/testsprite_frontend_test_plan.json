  {
    "id": "TC008",
    "title": "Authentication required messaging when attempting dashboard access (in-session unauthenticated)",
    "description": "Verifies the app shows an authentication-required message when the session is not authorized and dashboard access is attempted.",
    "category": "Dashboard analytics and widgets",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"invalid_user@example.com\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"wrong-password\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Invalid\" is visible"
      },
      {
        "type": "action",
        "description": "Navigate to /en/authentication"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Authentication\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"required\" is visible"
      }
    ]
  },
