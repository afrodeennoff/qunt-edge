[
  {
    "id": "TC001",
    "title": "Dashboard loads with core analytics widgets and charts visible (authenticated)",
    "description": "Verifies an authenticated user can open the dashboard and see key widgets/charts rendered.",
    "category": "Dashboard analytics and widgets",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Charts\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"Trades\" is visible"
      }
    ]
  },
